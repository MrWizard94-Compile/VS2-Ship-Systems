{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Minecraft Client",
      "request": "launch",
      "mainClass": "net.minecraftforge.bootstrap.ForgeBootstrap",
      "vmArgs": "-Xmx3G -Xms1G",
      "args": "--launchTarget forgeclient --fml.forgeVersion ${config:forge.version} --fml.mcVersion ${config:minecraft.version} --fml.forgeGroup net.minecraftforge",
      "env": {
        "FORGE_SPECIFIC": "true"
      },
      "cwd": "${workspaceFolder}/run",
      "preLaunchTask": "gradlew :prepareRuns"
    },
    {
      "type": "java",
      "name": "Minecraft Server",
      "request": "launch",
      "mainClass": "net.minecraftforge.bootstrap.ForgeBootstrap",
      "vmArgs": "-Xmx3G -Xms1G",
      "args": "--launchTarget forgeserver --fml.forgeVersion ${config:forge.version} --fml.mcVersion ${config:minecraft.version} --fml.forgeGroup net.minecraftforge",
      "cwd": "${workspaceFolder}/run",
      "preLaunchTask": "gradlew :prepareRuns"
    },
    {
      "type": "java",
      "name": "Minecraft Data Generator",
      "request": "launch",
      "mainClass": "net.minecraftforge.bootstrap.ForgeBootstrap",
      "vmArgs": "-Xmx3G -Xms1G",
      "args": "--launchTarget forgeclient --fml.forgeVersion ${config:forge.version} --fml.mcVersion ${config:minecraft.version} --fml.forgeGroup net.minecraftforge --mod vs2_ship_systems --all --output ${workspaceFolder}/src/generated/resources --existing ${workspaceFolder}/src/main/resources",
      "cwd": "${workspaceFolder}/run",
      "preLaunchTask": "gradlew :prepareRuns"
    }
  ]
}
