# Auto detect text files and normalize line endings
* text=auto

# Force Windows line endings for batch files
*.bat text eol=crlf

# Force Unix line endings for shell scripts
*.sh text eol=lf
gradlew text eol=lf

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.zip binary
gradle-wrapper.jar binary

# Gradle
*.gradle text
gradle.properties text
settings.gradle text
